# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
BASE_DIR=.
DATA_DIR=data
OUTPUTS_DIR=data/outputs
RAW_DIR=data/raw
OUTPUT_LANGUAGE=ko

# -----------------------------------------------------------------------------
# LLM / Ollama
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
PRIMARY_MODEL=qwen2.5:7b
GEMMA4_MODEL=gemma4:e4b
ENABLE_EXPERIMENTAL_FALLBACK=false
EXPERIMENTAL_FALLBACK_MODEL=gemma4:e4b
BASE_MODEL_NAME=meta-llama/Llama-2-7b-hf
ADAPTER_MODEL_NAME=FinGPT/fingpt-mt_llama2-7b_lora
ENABLE_4BIT=true
MAX_NEW_TOKENS=384
HF_TOKEN=
HF_MODEL_REVISION=main
FINGPT_DATASETS_ENABLED=false
FINGPT_DATASET_CACHE_DIR=data/fingpt_datasets
FINGPT_DATASET_MAX_ROWS=500
FINGPT_TASK_MODEL_ENABLED=false
FINGPT_TASK_MODEL_NAME=FinGPT/fingpt-mt_llama3-8b_lora

# -----------------------------------------------------------------------------
# Vector DB / Qdrant
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COLLECTION_NAME=market_docs
COLLECTION_CACHE_TTL_S=300
COLLECTION_CACHE_MAX_ENTRIES=32
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_VECTOR_SIZE=384
RETRIEVAL_STRATEGY=multi_query
RERANKER_ENABLED=true
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANKER_CANDIDATE_POOL=30
INGEST_CHUNKING_ENABLED=true
INGEST_CHUNK_TOKENS=512
INGEST_CHUNK_OVERLAP=64
MAX_CHUNKS_PER_PARENT=1
HYBRID_SEARCH_ENABLED=true
HYBRID_SEARCH_AUTO_MIGRATE_SPARSE=true
SPARSE_MODEL=Qdrant/bm25

# -----------------------------------------------------------------------------
# Market / financial data providers
# -----------------------------------------------------------------------------
DATA_PROVIDER_PRIORITY=yfinance,sec,google,openbb,alpha_vantage,fmp
ALPHA_VANTAGE_ENABLED=false
ALPHA_VANTAGE_API_KEY=
OPENBB_ENABLED=true
OPENBB_NEWS_ENABLED=false
FMP_ENABLED=false
FMP_API_KEY=
TRANSCRIPT_PROVIDER=fmp_optional
FRED_API_KEY=
SEC_USER_AGENT=FinGPTLocalResearch/1.0 contact@example.com
SEC_REQUEST_DELAY_S=0.12
FUNDAMENTALS_CARD_ENABLED=true
FUNDAMENTALS_CARD_TIMEOUT_S=8
RISK_ENGINE=heuristic
FINBERT_MODEL_NAME=ProsusAI/finbert

# -----------------------------------------------------------------------------
# Korean macro / DART / ECOS
# -----------------------------------------------------------------------------
DART_API_KEY=
DART_REQUEST_TIMEOUT_S=12
ECOS_API_KEY=
MACRO_PROVIDER_TIMEOUT_S=8
MACRO_YAHOO_DEFAULT_PERIOD=5y
MACRO_PRICE_LOOKBACK_DAYS=90
MACRO_NEWS_QUERY_LANGUAGE=en

# -----------------------------------------------------------------------------
# Data mart / refresh policy
# -----------------------------------------------------------------------------
DATA_MART_BACKEND=sqlite
DATA_MART_DB_PATH=data/research_mart.db
DATA_MART_DUCKDB_PATH=data/research_mart.duckdb
DATA_MART_AUTO_REFRESH_ENABLED=true
DATA_MART_AUTO_REFRESH_SEC_ENABLED=true
DATA_MART_AUTO_REFRESH_MACRO_ENABLED=true
DATA_MART_AUTO_REFRESH_INTERVAL_HOURS=24
DATA_MART_AUTO_REFRESH_INITIAL_DELAY_S=120
DATA_MART_AUTO_REFRESH_UNIVERSE_ID=all_supported
DATA_MART_AUTO_REFRESH_MAX_ASSETS=250
DATA_MART_AUTO_REFRESH_SEC_LOOKBACK_DAYS=1095
DATA_MART_AUTO_REFRESH_MACRO_LOOKBACK_DAYS=1825
AI_PORTFOLIO_DATA_DIR=data/ai_portfolio
AI_PORTFOLIO_DB_PATH=data/ai_portfolio/ai_portfolio.sqlite3
QUANTAMENTAL_DATA_DIR=data/quantamental

# -----------------------------------------------------------------------------
# Web/API server
# -----------------------------------------------------------------------------
WEB_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8010,http://localhost:8010
OPENBB_AGENT_ENABLED=false
OPENBB_AGENT_ID=fingpt-local-research
OPENBB_AGENT_NAME=FinGPT Local Research
OPENBB_AGENT_PUBLIC_URL=http://127.0.0.1:8000
OPENBB_AGENT_ALLOW_ORIGINS=https://pro.openbb.co,http://localhost:1420,http://127.0.0.1:1420

# -----------------------------------------------------------------------------
# Notifications / optional integrations
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Quant Lab / ML Forecast / scenario analysis
# -----------------------------------------------------------------------------
QUANT_LAB_QLIB_ENABLED=false
QLIB_PROVIDER_URI=
FORECAST_JOB_WORKERS=1
FORECAST_ARTIFACT_SIGNING_KEY=
FORECAST_AI_MAX_LATENCY_S=8
SCENARIO_SIMULATION_ENABLED=false
SCENARIO_SIMULATION_MAX_PERSONAS=6
SCENARIO_SIMULATION_MIN_PERSONAS=5
SCENARIO_SIMULATION_DEBATE_ROUNDS=1
SCENARIO_SIMULATION_MAX_SCENARIOS=4
SCENARIO_SIMULATION_LLM_ENABLED=true
SCENARIO_SIMULATION_STRICT_EVIDENCE=true
SCENARIO_SIMULATION_FAIL_OPEN=true
TOPIC_MODE_ENABLED=true
ROUTER_MODEL=qwen2.5:7b
TOPIC_RETRIEVAL_TOP_K=15
TOPIC_MAX_RELATED_TICKERS=8

# -----------------------------------------------------------------------------
# Development / testing
# -----------------------------------------------------------------------------
# Typecheck policy: mypy is not a required gate yet. The supported local/CI
# quality gates are active-scope ruff, compileall, pytest, env example check,
# UI contract smoke, and Docker compose config --quiet.
FINGPT_BROWSER_UI_HEADLESS=1
FINGPT_BUILD_ID=
FINGPT_GIT_COMMIT=
FINGPT_GIT_BRANCH=
FINGPT_VALIDATION_FAST_INFERENCE=false
FINGPT_VALIDATION_INFERENCE_TIMEOUT_S=20
FINGPT_VALIDATION_CHILD_FORCE_EXIT=1
